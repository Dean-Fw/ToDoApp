<ContentNavigationDrawer>:

	MDList:
		OneLineIconListItem:
			text:"Home"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "homeScreen"
			IconLeftWidget:
				icon: "home"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "homeScreen"
		OneLineIconListItem:
			text:"My ToDo lists"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "ToDoScreen"
			IconLeftWidget:
				icon: "format-list-bulleted"
				on_press: 
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "ToDoScreen"
		OneLineIconListItem:
			text: "Calender"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "calenderScreen"
			IconLeftWidget:
				icon: "calendar"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "calenderScreen"
		OneLineIconListItem:
			text: "Diary"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "diaryScreen"
			IconLeftWidget:
				icon: "book"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "diaryScreen"
		OneLineIconListItem:
			text: "Settings"
			on_press: 
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "settingsScreen"
			IconLeftWidget:
				icon: "cog"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "settingsScreen"
MDScreen:
	MDTopAppBar:
		pos_hint: {"top": 1}
		elevation: 4
		title: "ToDo"
		left_action_items:
			[["menu", lambda x: nav_drawer.set_state("open")]]	
	
	MDNavigationLayout:
		MDScreenManager:
			id: screen_manager
			
			MDScreen:
				name: "homeScreen"
				MDLabel:
					text: "Home Screen"
					halign: "center"
	
			MDScreen:
				name: "ToDoScreen"
				MDLabel:
					text: "View of ToDoLists"
					halign: "center"
				MDFloatingActionButton:
					icon: "plus"
					pos_hint: {"right": 1}
					on_release:
						screen_manager.current = "ToDo-CreateList-Screen"	
			MDScreen:
				name: "ToDo-CreateList-Screen"
				MDLabel:
					text: "Create a ToDo list!"
					halign: "center"
			MDScreen:
				name: "calenderScreen"
				MDLabel:
					text: "Calender"
					halign: "center"
			MDScreen:
				name: "diaryScreen"
				MDLabel:
					text: "Diary"
					halign: "center"

			MDScreen:
				name: "settingsScreen"
				MDLabel:
					text: "Settings"
					halign: "center"
			
	MDNavigationDrawer:
		id: nav_drawer
		ContentNavigationDrawer:
			screen_manager: screen_manager
			nav_drawer: nav_drawer





	
			
