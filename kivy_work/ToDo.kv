<ContentNavigationDrawer>:

	MDList:
		OneLineIconListItem:
			text:"Home"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "homeScreen"
			IconLeftWidget:
				icon: "home"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "homeScreen"
		OneLineIconListItem:
			text:"My ToDo lists"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "ToDoScreen"
			IconLeftWidget:
				icon: "format-list-bulleted"
				on_press: 
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "ToDoScreen"
		OneLineIconListItem:
			text: "Calender"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "calenderScreen"
			IconLeftWidget:
				icon: "calendar"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "calenderScreen"
		OneLineIconListItem:
			text: "Diary"
			on_press:
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "diaryScreen"
			IconLeftWidget:
				icon: "book"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "diaryScreen"
		OneLineIconListItem:
			text: "Settings"
			on_press: 
				root.nav_drawer.set_state("close")
				root.screen_manager.current = "settingsScreen"
			IconLeftWidget:
				icon: "cog"
				on_press:
					root.nav_drawer.set_state("close")
					root.screen_manager.current = "settingsScreen"

<ToDoListCreation>:
	MDBoxLayout:
		orientation: "vertical"
		padding: 10, 50, 10, 10
		MDLabel:
			text: "Create a ToDo list!"
			halign: "center"
			font_size: dp(20)
			size_hint: 1,None
			size: self.width, self.height
			pos_hint: {"top": 0.5 + self.height/2}	
		MDTextField:
			id: listNameField
			hint_text: "Enter a name for your ToDo list!"
			halign: "center"
			font_size: dp(20)
		MDGridLayout:
			cols: 3
			MDRaisedButton:
				id: discardBut
				text: "Discard ToDo list"
				pos_hint_x: {"left":1}
				on_press:
					root.screen_manager.current = "ToDoScreen"
			Widget:
			MDRaisedButton:
				id: saveBut
				text: "Save ToDo list"
				pos_hint_x: {"right":1}
				on_press:
					root.saveTask()

<ToDoScreen>:
	MDBoxLayout:
		oreintation: "vertical"			
		padding: 10,10,10,10
		ScrollView:
			MDList:
				id: ListOfToDoLists
		MDFloatingActionButton:
			icon: "plus"
			pos_hint: {"right": 1}
			on_release:
				root.screen_manager.current = "ToDo-CreateList-Screen"	

	


MDScreen:
	MDTopAppBar:
		id: ToolBar
		pos_hint: {"top": 1}
		elevation: 4
		title: "ToDo"
		left_action_items:
			[["menu", lambda x: nav_drawer.set_state("open")]]	
	
	MDNavigationLayout:
		MDScreenManager:
			id: screen_manager
			
			MDScreen:
				name: "homeScreen"
				MDLabel:
					text: "Home Screen"
					halign: "center"
	
			MDScreen:
				name: "ToDoScreen"
				ToDoScreen:
					screen_manager: screen_manager
			MDScreen:	
				name: "ToDo-CreateList-Screen"
				ToDoListCreation:
					screen_manager: screen_manager
			MDScreen:
				name: "calenderScreen"
				MDLabel:
					text: "Calender"
					halign: "center"
			MDScreen:
				name: "diaryScreen"
				MDLabel:
					text: "Diary"
					halign: "center"

			MDScreen:
				name: "settingsScreen"
				MDLabel:
					text: "Settings"
					halign: "center"
			
	MDNavigationDrawer:
		id: nav_drawer
		ContentNavigationDrawer:
			screen_manager: screen_manager
			nav_drawer: nav_drawer





	
			
